Bootstrap: docker
From: ubuntu:22.04

%labels
    Maintainer Antigravity
    Version 22.22
    Source /home/bougui/source/marvin/marvin_linux_22.22_openjdk11.deb

%files
    /home/bougui/source/marvin/marvin_linux_22.22_openjdk11.deb /opt/marvin.deb

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update && apt-get install -y --no-install-recommends \
        libfontconfig1 \
        libxrender1 \
        libxtst6 \
        libxi6 \
        libxext6 \
        libasound2 \
        libxcomposite1 \
        libxcursor1 \
        libxdamage1 \
        libxfixes3 \
        libxrandr2 \
        libatk1.0-0 \
        libgtk-3-0 \
        ca-certificates \
        shared-mime-info \
        xdg-utils \
        libdbus-1-3 \
        libnss3 \
        libgbm1 \
        libasound2 \
        x11-apps \
        && apt-get clean

    # Install the Marvin package
    # dpkg -i might fail due to missing dependencies if any were missed above, 
    # but apt-get install -f will resolve them.
    dpkg -i /opt/marvin.deb || apt-get install -y -f
    
    # Clean up the installer
    rm /opt/marvin.deb

%environment
    export LC_ALL=C
    export PATH=/opt/chemaxon/marvinsuite/bin:/opt/chemaxon/marvinsuite:$PATH

%runscript
    exec mview "$@"

%help
    This container runs ChemAxon MarvinView (mview).
    
    USAGE:
    To run with X11 forwarding from a Linux host:
    apptainer run --bind /tmp/.X11-unix:/tmp/.X11-unix -e DISPLAY=${DISPLAY} marvinview.sif [args...]

    To provide a license file:
    apptainer run --bind /path/to/license.cxl:/home/$(whoami)/.chemaxon/license.cxl ... marvinview.sif
